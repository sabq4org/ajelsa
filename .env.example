# ════════════════════════════════════════
# AJEL NEWSPAPER — ENVIRONMENT VARIABLES
# ════════════════════════════════════════

# ━━━━━━━━━━━━ Database (Neon PostgreSQL) ━━━━━━━━━━━━
# https://console.neon.tech
DATABASE_URL="postgresql://user:pass@host.neon.tech/ajel?sslmode=require"

# ━━━━━━━━━━━━ Authentication ━━━━━━━━━━━━
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-32-char-secret-here-change-in-production"
AUTH_COOKIE_NAME="ajel_session"
JWT_SECRET="another-32-char-secret"

# ━━━━━━━━━━━━ AI Services ━━━━━━━━━━━━

# OpenAI — للتحرير الذكي + DALL-E 3
# https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-..."

# Google Gemini — للصور الواقعية (Imagen 4)
# https://aistudio.google.com/apikey
GEMINI_API_KEY="AIza..."

# ━━━━━━━━━━━━ Image Storage ━━━━━━━━━━━━

# Cloudinary (الأساسي — موصى به)
# https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="123456789"
CLOUDINARY_API_SECRET="your-secret"

# Cloudflare R2 (احتياطي — اختياري)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ━━━━━━━━━━━━ Cache & Search (اختياري) ━━━━━━━━━━━━

# Upstash Redis
REDIS_URL=""

# Meilisearch
MEILISEARCH_HOST=""
MEILISEARCH_API_KEY=""

# ━━━━━━━━━━━━ Revalidation ━━━━━━━━━━━━
# سر للحماية من تجديد الكاش العشوائي (اختياري)
REVALIDATE_SECRET="random-secret-for-revalidate-endpoint"

# ━━━━━━━━━━━━ Site Config ━━━━━━━━━━━━
NEXT_PUBLIC_SITE_URL="https://ajelsa.vercel.app"
NEXT_PUBLIC_SITE_NAME="عاجل"
