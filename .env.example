# ====================================
# AJEL NEWSPAPER - ENVIRONMENT VARIABLES
# ====================================

# --- Database (Neon PostgreSQL) ---
# Get from https://console.neon.tech
DATABASE_URL="postgresql://user:pass@host.neon.tech/ajel?sslmode=require"

# --- Authentication ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-32-char-secret-here-change-in-production"
AUTH_COOKIE_NAME="ajel_session"

# --- Redis (Upstash or self-hosted) ---
REDIS_URL="redis://localhost:6379"

# --- Meilisearch ---
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_API_KEY="your-meilisearch-master-key"

# --- Cloudflare R2 (S3-compatible) ---
R2_ACCOUNT_ID="your-cf-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret"
R2_BUCKET_NAME="ajel-media"
R2_PUBLIC_URL="https://cdn.ajel.sa"

# --- Site Config ---
NEXT_PUBLIC_SITE_URL="https://ajel.sa"
NEXT_PUBLIC_SITE_NAME="عاجل"
